# ========== 认知花园 环境变量示例 ==========
# 复制为 .env 并按需修改

# ---- 数据库 ----
# 生产用 PostgreSQL；开发/测试可留空走 SQLite
# database_url=postgresql+psycopg2://cg_user:cg_pass@localhost:5432/cognitive_garden

# ---- Redis ----
# 限流、SSE Pub/Sub、token 黑名单共享存储
# redis_url=redis://localhost:6379/0

# ---- JWT ----
# access token 有效期（分钟），默认 30
# access_token_expire_minutes=30
# refresh token 有效期（天），默认 7
# refresh_token_expire_days=7
# 自定义 JWT 密钥（不设则自动生成并持久化到 ~/.cognitive-garden/secret.json）
# CG_JWT_SECRET=

# ---- KMS / 主密钥管理 ----
# provider: local（开发）/ env（单机生产）/ aws（云上生产）
# kms_provider=local
# env 模式：base64 编码的 32 字节密钥
#   生成方式：python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# kms_master_key=
# aws 模式：KMS Key ID 和区域
# kms_key_id=
# kms_aws_region=us-east-1

# ---- 审计日志 ----
# audit_log_enabled=true

# ---- 调试 ----
# debug=false
