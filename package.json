{
  "name": "cognitive-garden-root",
  "version": "2.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "dev:backend": "cd backend && python run.py",
    "dev:full": "concurrently \"npm run dev:backend\" \"npm run tauri:dev\"",
    "build": "npm run build --prefix frontend",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run build --prefix frontend && tauri build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^1.5.0",
    "concurrently": "^8.2.2"
  }
}
